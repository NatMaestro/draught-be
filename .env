# Draught Backend - Environment Variables
# Copy to .env and adjust

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (required) — e.g. Neon. Startup prints: [Draught] PostgreSQL connection established - ...
#
# Connection TIMEOUT is a network issue (firewall/ISP/VPN), not wrong password.
# Neon troubleshooting: dashboard Connect (try Direct vs Pooler), IP allowlist, phone hotspot, firewall.
#
DATABASE_URL=postgresql://neondb_owner:npg_xgFV78wOYjzU@ep-fancy-leaf-adkh0fj3-pooler.c-2.us-east-1.aws.neon.tech:5432/neondb?sslmode=require
DATABASE_CONNECT_TIMEOUT=180

# Redis - for matchmaking and WebSocket scaling
REDIS_URL=redis://default:nNgPHTrsxH52Bf7ydm5lbkjuduSGdpnG@redis-15262.c325.us-east-1-4.ec2.cloud.redislabs.com:15262

# Use Redis for channel layers (set True when Redis is running)
USE_REDIS_CHANNELS=True

# ELO
