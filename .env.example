# Draught Backend - Environment Variables
# Copy to .env and adjust

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — PostgreSQL required (e.g. Neon). Startup logs: [Draught] PostgreSQL connection established - ...
# DATABASE_CONNECT_TIMEOUT=180
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT (SimpleJWT) — access expires often; refresh lasts days (client stores both)
# JWT_ACCESS_MINUTES=60
# JWT_REFRESH_DAYS=7

# Redis - for matchmaking and WebSocket scaling
REDIS_URL=redis://127.0.0.1:6379/0

# Use Redis for channel layers (set True when Redis is running)
USE_REDIS_CHANNELS=False

# ELO
ELO_K_FACTOR=32
ELO_INITIAL_RATING=1000

# Ranked matchmaking — rating gap allowed widens while you wait (see apps.matchmaking.services)
# MATCHMAKING_RANKED_INITIAL_DELTA=150
# MATCHMAKING_RANKED_MAX_DELTA=500
# MATCHMAKING_RANKED_EXPAND_EVERY_SEC=15
# MATCHMAKING_RANKED_EXPAND_STEP=25

# Facebook Login (optional) — link accounts + friend suggestions (`/me/friends` = friends who use this app)
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# TikTok Login Kit (optional) — link account only (no friend graph for third-party apps)
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI=http://localhost:5173/play/friends

# Web Push (optional) — leave empty to disable push; in-app notifications still work.
# Generate a VAPID key pair and paste the public + private PEM or raw keys your tooling expects.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com

# Production (Render, etc.) — set when DEBUG=False
# ALLOWED_HOSTS=draught-api.onrender.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com
# CSRF: required for /admin/ login (same host as API). Set explicitly or rely on RENDER_EXTERNAL_URL on Render.
# CSRF_TRUSTED_ORIGINS=https://draught-api.onrender.com
# DATABASE_URL=postgres://...
